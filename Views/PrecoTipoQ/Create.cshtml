@model ReserveSystem.Models.PrecoTipoQuarto

@{
    ViewData["Title"] = "Create new Room Type";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - PrecoTipoQuarto</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #faf3e0; /* Light pastel background */
            font-family: 'Arial', sans-serif;
        }

        .container {
            margin-top: 50px;
            background-color: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }

        h1, h4 {
            color: #5d5c61;
        }

        .btn-primary {
            background-color: #a58970;
            border: none;
        }

            .btn-primary:hover {
                background-color: #866d57;
            }

        .btn-secondary {
            background-color: #d3d3d3;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #bfbfbf;
            }

        .form-group label {
            font-weight: bold;
            color: #5d5c61;
        }

        .form-control {
            border: 1px solid #ced4da;
            border-radius: .25rem;
        }

            .form-control:focus {
                border-color: #a58970;
                box-shadow: 0 0 0 .2rem rgba(165, 137, 112, .25);
            }

        .text-danger {
            color: #e74c3c;
        }

        .card {
            background-color: #ffffff;
            border: 1px solid #d3d3d3;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1 class="text-center">@ViewData["Title"]</h1>
        <h4 class="text-center">PrecoTipoQuarto</h4>
        <hr />
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="form-group">
                            <label asp-for="tipo" class="control-label"></label>
                            <input asp-for="tipo" class="form-control" />
                            <span asp-validation-for="tipo" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="capacidade" class="control-label"></label>
                            <input asp-for="capacidade" class="form-control" />
                            <span asp-validation-for="capacidade" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="quantidadeQuartos" class="control-label"></label>
                            <input asp-for="quantidadeQuartos" class="form-control" />
                            <span asp-validation-for="quantidadeQuartos" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="PrecoBase" class="control-label"></label>
                            <input asp-for="PrecoBase" class="form-control" />
                            <span asp-validation-for="PrecoBase" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="taxaCancelamento" class="control-label"></label>
                            <input asp-for="taxaCancelamento" class="form-control" />
                            <span asp-validation-for="taxaCancelamento" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="camaAdiconal" class="control-label"></label>
                            <input asp-for="camaAdiconal" class="form-control" />
                            <span asp-validation-for="camaAdiconal" class="text-danger"></span>
                        </div>

                        <div class="form-group form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" asp-for="QuartoAdaptado" /> @Html.DisplayNameFor(model => model.QuartoAdaptado)
                            </label>
                        </div>

                        <div class="form-group form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" asp-for="Vista" /> @Html.DisplayNameFor(model => model.Vista)
                            </label>
                        </div>
                        
                        <div class="form-group text-center">
                            <input type="submit" value="Create" class="btn btn-primary" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="text-center mt-3">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</body>
</html>


