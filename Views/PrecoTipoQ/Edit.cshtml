@model ReserveSystem.Models.PrecoTipoQuarto

@{
    ViewData["Title"] = "Edit Price for Room Type";
}

<style>
    
    body {
        font-family: 'Georgia', serif;
        background-color: #f9f9f6; 
        color: #1a1a1a; 
    }

    
    .form-container {
        background: #ffffff; 
        padding: 4rem;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1); 
        max-width: 750px; 
        margin: 3rem auto;
        transition: all 0.3s ease;
    }

    .form-container:hover {
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15); 
    }

    h1 {
        font-size: 2rem;
        color: #d4af37;
    }


    .form-group label {
        font-size: 1.2rem;
        color: #1a1a1a; 
        font-weight: 600;
        margin-bottom: 0.5rem; 
    }

    
    .form-control {
        border-radius: 8px;
        border: 1px solid #cccccc;
        padding: 14px 18px; 
        font-size: 1.1rem; 
        transition: all 0.3s ease;
        background-color: #f9f9f9;
        width: 100%; 
    }

    .form-control:focus {
        border-color: #d4af37; 
        box-shadow: 0 0 8px rgba(212, 175, 55, 0.2); 
        background-color: #ffffff; 
    }

    
    .form-check-input:checked {
        background-color: #d4af37; 
        border-color: #d4af37;
    }

    .form-check-label {
        color: #555555; 
        font-size: 1.1rem; 
    }

   
    .text-danger {
        font-size: 1rem;
        color: #cc0000; 
    }

    
    .btn_edit {
        background-color: #ffffff;
        border-color: #d4af37;
        color: #333333;
        font-weight: 600;
        padding: 16px 32px;
        border-radius: 50px;
        font-size: 1.25rem; 
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        width: 60%; 
        margin-top: 2rem;
    }

    .btn_edit:hover {
        background-color: #333333;
        color: #F5F5F5;
        border-color: #d4af37;
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        transform: translateY(-3px);
    }

    .btn_edit:active {
        background-color: #000000; 
        border-color: #000000;
        color: white;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); 
        transform: translateY(0); 
    }

    .btn_back {
        background-color: #333333;
        border-color: #d4af37;
        color: #ffffff;
        font-weight: 600;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 1.125rem;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

    .btn_back:hover {
        background-color: #ffffff;
        color: #d4af37;
        border-color: #d4af37;
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        transform: translateY(-3px);
    }

    .hr {
        border: none;
        height: 2px;
        background-color: #d4af37; 
        width: 60%;
        margin: 1rem auto;
        opacity: 0.8;
    }
</style>

<h1 class="text-center">Edit Price for Room Type</h1>
<hr class="hr" />
<div class="form-container">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
        <input type="hidden" asp-for="id_RTPrice" />

        
        <div class="form-group my-2">
            <label asp-for="TipoQuartoId" class="control-label">Room Type</label>
            <select asp-for="TipoQuartoId" class="form-control" asp-items="ViewBag.TipoQuartoId"></select>
            <span asp-validation-for="TipoQuartoId" class="text-danger"></span>
        </div>

      
        <div class="form-group my-2">
            <label asp-for="BasePrice" class="control-label">Base Price</label>
            <input asp-for="BasePrice" class="form-control" />
            <span asp-validation-for="BasePrice" class="text-danger"></span>
        </div>

        
        <div class="form-group my-2">
            <label asp-for="CancelationFee" class="control-label">Cancellation Fee</label>
            <input asp-for="CancelationFee" class="form-control" />
            <span asp-validation-for="CancelationFee" class="text-danger"></span>
        </div>

        
        <div class="form-group my-2">
            <label asp-for="AdicionalBeds" class="control-label">Additional Beds Price</label>
            <input asp-for="AdicionalBeds" class="form-control" />
            <span asp-validation-for="AdicionalBeds" class="text-danger"></span>
        </div>

        <div class="form-group text-center my-2">
            <input type="submit" value="Save" class="btn btn_edit" />
        </div>
    </form>
    <div class="text-center mt-4">
        <a asp-action="Index" class="btn btn_back">Back to List</a>
    </div>
