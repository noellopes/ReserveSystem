@model ReserveSystem.Models.TipoQuarto

@{
    ViewData["Title"] = "Edit";
}

<style>
    body {
        font-family: 'Georgia', serif;
        background-color: #f9f9f6;
        color: #1a1a1a;
    }

    .form-container {
        background: #ffffff;
        padding: 4rem;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        max-width: 750px;
        margin: 3rem auto;
        transition: all 0.3s ease;
    }

        .form-container:hover {
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }

    h1 {
        font-size: 2rem;
        color: #d4af37;
    }

    .form-group label {
        font-size: 1.2rem;
        color: #1a1a1a;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #cccccc;
        padding: 14px 18px;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        background-color: #f9f9f9;
        width: 100%;
    }

        .form-control:focus {
            border-color: #d4af37;
            box-shadow: 0 0 8px rgba(212, 175, 55, 0.2);
            background-color: #ffffff;
        }

    .form-check-input:checked {
        background-color: #d4af37;
        border-color: #d4af37;
    }

    .form-check-label {
        color: #555555;
        font-size: 1.1rem;
    }

    .text-danger {
        font-size: 1rem;
        color: #cc0000;
    }

    .btn_edit {
        background-color: #ffffff;
        border-color: #d4af37;
        color: #333333;
        font-weight: 600;
        padding: 16px 32px;
        border-radius: 50px;
        font-size: 1.25rem;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        width: 60%;
        margin-top: 2rem;
    }

        .btn_edit:hover {
            background-color: #333333;
            color: #F5F5F5;
            border-color: #d4af37;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            transform: translateY(-3px);
        }

        .btn_edit:active {
            background-color: #000000;
            border-color: #000000;
            color: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transform: translateY(0);
        }

    .btn_back {
        background-color: #333333;
        border-color: #d4af37;
        color: #ffffff;
        font-weight: 600;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 1.125rem;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

        .btn_back:hover {
            background-color: #ffffff;
            color: #d4af37;
            border-color: #d4af37;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            transform: translateY(-3px);
        }

    .hr {
        border: none;
        height: 2px;
        background-color: #d4af37;
        width: 60%;
        margin: 1rem auto;
        opacity: 0.8;
    }
</style>

<h1 class="text-center">Edit Room Type</h1>
<hr class="hr" />
<div class="form-container">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
        <input type="hidden" asp-for="TipoQuartoId" />

        <div class="form-group my-2">
            <label asp-for="type" class="control-label">Room Type</label>
            <input asp-for="type" class="form-control" />
            <span asp-validation-for="type" class="text-danger"></span>
        </div>

        <div class="form-group my-2">
            <label asp-for="capacity" class="control-label">Room Capacity</label>
            <input asp-for="capacity" class="form-control" />
            <span asp-validation-for="capacity" class="text-danger"></span>
        </div>

        <div class="form-group my-2">
            <label asp-for="RoomQuantity" class="control-label">Room Quantity</label>
            <input asp-for="RoomQuantity" class="form-control" />
            <span asp-validation-for="RoomQuantity" class="text-danger"></span>
        </div>

        <div class="form-group form-check my-2">
            <input class="form-check-input" asp-for="AcessibilityRoom" />
            <label class="form-check-label" asp-for="AcessibilityRoom">Room with Accessibility</label>
        </div>

        <div class="form-group form-check my-2">
            <input class="form-check-input" asp-for="View" />
            <label class="form-check-label" asp-for="View">Room with View</label>
        </div>

        <div class="form-group text-center my-2">
            <input type="submit" value="Save" class="btn btn_edit" />
        </div>
    </form>

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn btn_back">Back to List</a>
    </div>
</div>
<hr class="hr" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
